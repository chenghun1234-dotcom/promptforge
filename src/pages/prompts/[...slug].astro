---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const modules = import.meta.glob('../../content/prompts/*.md', { eager: true });
	return Object.entries(modules).map(([path, mod]: [string, any]) => {
		const slug = path.split('/').pop()?.replace(/\.md$/, '') ?? 'untitled';
		return {
			params: { slug },
			props: { mod, slug },
		};
	});
}

const { mod } = Astro.props;
const Frontmatter = mod.frontmatter ?? {};
const Content = mod.Content;
---

<Layout title={Frontmatter.title ?? 'Prompt'} description={Frontmatter.description}>
	<main class="mx-auto max-w-3xl px-6 py-12">
		<header class="mb-10">
			<p class="font-mono text-xs text-green-400">{Frontmatter.model ?? 'LLM Forge'}</p>
			<h1 class="mt-2 text-3xl font-black md:text-4xl">{Frontmatter.title ?? 'Prompt'}</h1>
			{Frontmatter.description ? (
				<p class="mt-3 text-slate-400">{Frontmatter.description}</p>
			) : null}
		</header>

		<article class="space-y-6 leading-relaxed text-slate-200">
			<Content />
		</article>

		<section class="mt-12 rounded-xl border border-rose-500/30 bg-slate-900/70 p-6">
			<h2 class="text-xl font-bold text-white">🚀 추천 리소스</h2>
			<p class="mt-2 text-sm text-slate-300">
				프롬프트 결과를 더 빠르게 활용할 수 있는 도구와 프리미엄 프롬프트 번들을 확인해보세요.
			</p>
			<div class="mt-4 flex flex-col gap-3 sm:flex-row">
				<a
					href="https://www.creativefabrica.com/studio/ref/22296047/"
					target="_blank"
					rel="noopener noreferrer"
					data-affiliate-provider="CreativeFabrica"
					data-affiliate-location="detail_bottom_cta"
					data-prompt-id={Astro.params.slug ?? 'unknown'}
					class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2 text-sm font-bold text-black transition hover:bg-gray-200"
				>
					🎨 Try in AI Studio
				</a>
				<a
					href="https://www.creativefabrica.com/subscriptions/graphics/ai-prompts/ref/22296047/"
					target="_blank"
					rel="noopener noreferrer"
					data-affiliate-provider="CreativeFabrica"
					data-affiliate-location="detail_bottom_cta"
					data-prompt-id={Astro.params.slug ?? 'unknown'}
					class="inline-flex items-center justify-center rounded-lg bg-rose-500 px-4 py-2 text-sm font-bold text-white transition hover:bg-rose-400"
				>
					📦 Get Premium Prompt Pack
				</a>
			</div>
		</section>
	</main>
</Layout>
